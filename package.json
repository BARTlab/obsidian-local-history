{
  "name": "obsidian-line-change-tracker",
  "version": "1.0.2",
  "description": "Tracks and highlights changed lines in the editor with markers, show version diff, make local history for files changes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src tests",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:perf": "NODE_OPTIONS=--expose-gc jest --config jest.config.perf.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "editor",
    "diff",
    "changes"
  ],
  "author": "B@RT",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shellscape/esbuild-sass-plugin": "^2.4.4-patch.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "builtin-modules": "^5.2.0",
    "diff": "^9.0.0",
    "diff2html": "^3.4.56",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eventemitter3": "^5.0.4",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lodash-es": "^4.18.1",
    "obsidian": "^1.13.0",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.4.11",
    "tslib": "2.8.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "$esbuild"
  }
}
