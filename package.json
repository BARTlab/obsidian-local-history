{
  "name": "obsidian-line-change-tracker",
  "version": "2.0.5",
  "description": "Tracks and highlights changed lines in the editor with markers, show version diff, make local history for files changes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src tests && node scripts/check-class-purity.mjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:perf": "NODE_OPTIONS=--expose-gc vitest run --config vitest.config.perf.ts",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "editor",
    "diff",
    "changes"
  ],
  "author": "B@RT",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@eslint/js": "^10.0.1",
    "@profoundlogic/hogan": "^3.0.4",
    "@shellscape/esbuild-sass-plugin": "^2.4.4-patch.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "diff": "^9.0.0",
    "diff2html": "^3.4.56",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "eventemitter3": "^5.0.4",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "obsidian": "^1.13.0",
    "reflect-metadata": "^0.2.2",
    "tslib": "2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "$esbuild"
  }
}
